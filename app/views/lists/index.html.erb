<h1>All Lists</h1>

<div class="banner" style="background-image: url('<%= asset_path "cinema.jpg" %>');">
  Save any kind of movies
</div>

<div class="lists-container">
  <% @lists.each do |list| %>
    <div class="list-card" style="background-image: url('<%= asset_path "360.jpg" %>');">
      <h3><%= link_to list.name, list_path(list) %></h3>
    </div>
  <% end %>
</div>

<%= link_to "Create a new list", new_list_path, class: "btn btn-primary" %>
